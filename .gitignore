# Minimal, focused .gitignore for this repo
# Keep node deps, build artifacts, OS/IDE files, and common noise out of Git

# Node dependencies
node_modules/
**/node_modules/

# Build output
/build/
/dist/
/out/
client/build/
client/dist/
client/node_modules/
# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
logs/
*.log

# Test coverage
coverage/
.nyc_output/

# Runtime/pid files
pids/
*.pid
*.seed

# Environment files
.env
.env.local
.env.*.local

# Editor/IDE
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln

# macOS
.DS_Store
.AppleDouble
.LSOverride

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini

# Temporary files
tmp/
temp/
cache/
.cache/

# Misc
*.gz
*.zip
*.tar

# Ignore build artifacts from create-react-app that sometimes appear
/client/node_modules/
/server/node_modules/

# Keep the repo tidy: ignore IDE/workspace metadata
*.log.*
/.idea/
.expo/

# Lockfiles and install artifacts (generated by `npm install`)
package-lock.json
npm-shrinkwrap.json
yarn.lock
pnpm-lock.yaml
.pnp.*
.npm/
.package-lock.json

# Server/client build folders (generated by build commands)
/server/build/
/client/build/
/client/dist/


